[Unit]
Description=RemoteTrade Polymarket BTC 5m directional paper trading loop
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=remotetrade
Group=remotetrade
WorkingDirectory=/opt/remotetrade
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/remotetrade/.venv/bin/python -m remotetrade.app --patterns patterns.json --discord --discord-events-only
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
