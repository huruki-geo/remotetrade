# Polymarket market discovery.
# Set MARKET_SLUG for the exact market you want, or leave it empty and use MARKET_QUERY.
MARKET_SLUG=
MARKET_QUERY=BTC Up or Down 5m

# Coinbase product id used for the traded spot proxy.
CRYPTO_PRODUCT_ID=BTC-USD
CRYPTO_PRODUCT_IDS=BTC-USD,ETH-USD,SOL-USD

# Paper-trading parameters.
POLL_SECONDS=15
HOLD_SECONDS=300
ENTRY_THRESHOLD=0.06
STRONG_THRESHOLD=0.10
TAKE_PROFIT_PCT=0.004
STOP_LOSS_PCT=-0.0025
RISK_FRACTION=0.10
MAX_TRADE_SIZE_USD=30
MIN_TRADE_SIZE_USD=10
START_CASH_USD=300

# Cross-exchange arbitrage scanner.
ARBITRAGE_NOTIONAL_USD=100
ARBITRAGE_FEE_BPS=20
ARBITRAGE_MIN_NET_SPREAD_PCT=0.001
ARBITRAGE_SAFETY_BPS=5
LIMIT_MAKER_FEE_BPS=10
LIMIT_TAKER_FEE_BPS=20
LIMIT_PRICE_IMPROVEMENT_BPS=1.0
LIMIT_ORDER_TTL_TICKS=3
LIMIT_PAPER_VARIANTS=normal:0.001:1.0,loose:0.0005:1.0,strict:0.002:1.0

# Candle wick reversal scanner.
WICK_GRANULARITY_SECONDS=60
WICK_MIN_RATIO=0.55
WICK_MIN_RANGE_PCT=0.001

# Cross-exchange spread mean reversion.
SPREAD_WINDOW=30
SPREAD_ENTRY_ZSCORE=2.0
SPREAD_EXIT_ZSCORE=0.5
SPREAD_STOP_ZSCORE=4.0
SPREAD_NOTIONAL_USD=100

# Health checks.
HEALTH_MAX_TICK_AGE_SECONDS=300
HEALTH_MIN_FREE_DISK_MB=512

# Runtime output.
STATE_PATH=data/paper_state.json
TRADES_PATH=data/trades.csv
TICKS_PATH=data/ticks.csv
ARBITRAGE_TICKS_PATH=data/arbitrage_ticks.csv

# Optional Discord notifications.
DISCORD_WEBHOOK_URL=
